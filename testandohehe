def print_token_info(payload: dict, header: dict):
    """Exibe as informações extraídas do token de forma formatada."""
    print("\n" + "═" * 65)
    print("  🔑  INFORMAÇÕES DO JWT TOKEN")
    print("═" * 65)

    # Identidade
    print("\n📋  IDENTIDADE")
    print(f"  Usuário (sub):      {payload.get('sub', 'N/A')}")
    print(f"  Nome:               {payload.get('name', 'N/A')}")
    print(f"  Nome Completo:      {payload.get('given_name', '')} {payload.get('family_name', '')}")
    print(f"  Agent ID (icAgent): {payload.get('icAgentId', 'N/A')}")
    print(f"  SP ID (icSPId):     {payload.get('icSPId', 'N/A')}")
    print(f"  BU ID (icBUId):     {payload.get('icBUId', 'N/A')}")

    # Tenant
    print("\n🏢  TENANT")
    print(f"  Tenant ID:          {payload.get('tenantId', 'N/A')}")
    print(f"  Tenant Name:        {payload.get('tenant', 'N/A')}")
    print(f"  Cluster:            {payload.get('icClusterId', 'N/A')}")
    print(f"  Area:               {payload.get('area', 'N/A')}")
    print(f"  Domain:             {payload.get('icDomain', 'N/A')}")

    # Role / Permissões
    role = payload.get("role", {})
    if role:
        print("\n👤  ROLE / PERFIL")
        print(f"  Role ID:            {role.get('id', 'N/A')}")
        print(f"  Role Legacy ID:     {role.get('legacyId', 'N/A')}")
        sec_roles = role.get("secondaryRoles", [])
        if sec_roles:
            print(f"  Roles Secundários:  {', '.join(str(r) for r in sec_roles)}")

    # Validade do token
    iat = payload.get("iat")
    exp = payload.get("exp")
    print("\n⏰  VALIDADE")
    if iat:
        issued_at = datetime.fromtimestamp(iat, tz=timezone.utc)
        print(f"  Emitido em:         {issued_at.strftime('%Y-%m-%d %H:%M:%S UTC')}")
    if exp:
        expires_at = datetime.fromtimestamp(exp, tz=timezone.utc)
        now = datetime.now(tz=timezone.utc)
        remaining = exp - int(now.timestamp())
        status = f"⚠️  EXPIRADO há {abs(remaining)}s" if remaining < 0 else f"✅ válido por {remaining}s"
        print(f"  Expira em:          {expires_at.strftime('%Y-%m-%d %H:%M:%S UTC')}  [{status}]")

    # Header JWT
    print("\n🔏  HEADER JWT")
    print(f"  Algoritmo:          {header.get('alg', 'N/A')}")
    print(f"  Tipo:               {header.get('typ', 'N/A')}")
    print(f"  Key ID (kid):       {header.get('kid', 'N/A')}")

    # Audience / Issuer
    print("\n🌐  AUDIENCE / ISSUER")
    print(f"  Issuer (iss):       {payload.get('iss', 'N/A')}")
    print(f"  Audience (aud):     {payload.get('aud', 'N/A')}")

    print("═" * 65)


def test_endpoints(
    token: str,
    base_url: str,
    payload: dict,
    verbose: bool = False,
    delay: float = 0.3,
) -> dict:
    """
    Testa todos os endpoints configurados e retorna um dicionário com os resultados.
    """
    headers = {
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json",
        "Accept": "application/json",
    }

    results = {}
    total = sum(len(v) for v in ENDPOINT_GROUPS.values())
    tested = 0

    # Extrai IDs úteis do payload para substituir em paths dinâmicos
    agent_id = payload.get("icAgentId", "")
    bu_id = payload.get("icBUId", "")

    print(f"\n\n{'═' * 65}")
    print(f"  🔍  TESTANDO ACESSOS DA API  ({total} endpoints em {len(ENDPOINT_GROUPS)} grupos)")
    print(f"  Base URL: {base_url}")
    print("═" * 65)

    for group_name, endpoints in ENDPOINT_GROUPS.items():
        print(f"\n📁  {group_name}")
        print(f"  {'─' * 60}")
        results[group_name] = []

        for method, path, params in endpoints:
            tested += 1
            # Substitui placeholders no path, se houver
            path_resolved = path.format(
                agent_id=agent_id,
                bu_id=bu_id,
            )
            url = f"{base_url.rstrip('/')}{path_resolved}"

            try:
                if method == "GET":
                    resp = requests.get(url, headers=headers, params=params, timeout=10)
                elif method == "POST":
                    resp = requests.post(url, headers=headers, json=params, timeout=10)
                else:
                    resp = requests.request(method, url, headers=headers, timeout=10)

                code = resp.status_code
                accessible = is_accessible(code)
                status_str = format_status(code)

                entry = {
                    "method": method,
                    "path": path_resolved,
                    "status_code": code,
                    "accessible": accessible,
                }

                if verbose and accessible and code == 200:
                    # Mostra preview da resposta em modo verbose
                    try:
                        body = resp.json()
                        preview = json.dumps(body)[:120] + "..." if len(json.dumps(body)) > 120 else json.dumps(body)
                        entry["response_preview"] = preview
                    except Exception:
                        entry["response_preview"] = resp.text[:120]

                results[group_name].append(entry)

                indicator = "  ✅" if accessible else "  🚫"
                print(f"  [{tested:>3}/{total}] {indicator}  {method:<6} {path_resolved:<60} {status_str}")

                if verbose and entry.get("response_preview"):
                    print(f"            📄 {entry['response_preview']}")

            except requests.exceptions.ConnectionError:
                results[group_name].append({
                    "method": method,
                    "path": path_resolved,
                    "status_code": 0,
                    "accessible": False,
                    "error": "Connection error",
                })
                print(f"  [{tested:>3}/{total}]   ❌  {method:<6} {path_resolved:<60} ❌ Erro de conexão")
            except requests.exceptions.Timeout:
                results[group_name].append({
                    "method": method,
                    "path": path_resolved,
                    "status_code": 0,
                    "accessible": False,
                    "error": "Timeout",
                })
                print(f"  [{tested:>3}/{total}]   ⏳  {method:<6} {path_resolved:<60} ⏳ Timeout")
            except Exception as e:
                results[group_name].append({
                    "method": method,
                    "path": path_resolved,
                    "status_code": 0,
                    "accessible": False,
                    "error": str(e),
                })
                print(f"  [{tested:>3}/{total}]   ❌  {method:<6} {path_resolved:<60} ❌ {e}")

            time.sleep(delay)  # Evita rate limit

    return results


def print_summary(results: dict):
    """Exibe um resumo consolidado dos resultados."""
    print(f"\n\n{'═' * 65}")
    print("  📊  RESUMO DO MAPEAMENTO DE ACESSOS")
    print("═" * 65)

    total_accessible = 0
    total_blocked = 0

    for group, entries in results.items():
        accessible = [e for e in entries if e["accessible"]]
        blocked = [e for e in entries if not e["accessible"]]
        total_accessible += len(accessible)
        total_blocked += len(blocked)

        icon = "✅" if accessible else "🚫"
        print(f"\n{icon}  {group}  ({len(accessible)}/{len(entries)} acessíveis)")

        for e in accessible:
            print(f"     ✅  {e['method']:<6} {e['path']}  [{e['status_code']}]")
        for e in blocked:
            print(f"     🚫  {e['method']:<6} {e['path']}  [{e['status_code']}]")

    total = total_accessible + total_blocked
    pct = (total_accessible / total * 100) if total > 0 else 0
    print(f"\n{'═' * 65}")
    print(f"  TOTAL:  {total_accessible} acessíveis  /  {total_blocked} bloqueados  /  {total} testados")
    print(f"  COBERTURA:  {pct:.1f}% dos endpoints são acessíveis com este token")
    print("═" * 65)


def save_results(results: dict, payload: dict, base_url: str, output_path: str):
    """Salva os resultados em JSON."""
    output = {
        "scan_timestamp": datetime.now(tz=timezone.utc).isoformat(),
        "base_url": base_url,
        "token_info": {
            "sub": payload.get("sub"),
            "name": payload.get("name"),
            "tenant": payload.get("tenant"),
            "tenantId": payload.get("tenantId"),
            "icAgentId": payload.get("icAgentId"),
            "icBUId": payload.get("icBUId"),
            "role": payload.get("role"),
            "exp": payload.get("exp"),
        },
        "results": results,
    }
    with open(output_path, "w", encoding="utf-8") as f:
        json.dump(output, f, indent=2, ensure_ascii=False)
    print(f"\n💾  Resultados salvos em: {output_path}")


