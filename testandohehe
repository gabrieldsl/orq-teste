def main():
    parser = argparse.ArgumentParser(
        description="NICE CXone - Mapeador de acessos via JWT Token",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    parser.add_argument(
        "--token", "-t",
        required=True,
        help="JWT token do NICE CXone (access_token ou id_token)",
    )
    parser.add_argument(
        "--base-url", "-u",
        default=None,
        help="URL base da API (ex: https://api-na1.niceincontact.com).\n"
             "Se não fornecido, será detectado automaticamente via API Discovery.",
    )
    parser.add_argument(
        "--issuer", "-i",
        default="https://cxone.niceincontact.com",
        help="Issuer do CXone (padrão: https://cxone.niceincontact.com).\n"
             "Use https://cxone-gov.niceincontact.com para ambientes FedRAMP.",
    )
    parser.add_argument(
        "--output", "-o",
        default=None,
        help="Caminho do arquivo JSON para salvar os resultados.",
    )
    parser.add_argument(
        "--verbose", "-v",
        action="store_true",
        help="Modo verbose: exibe preview das respostas bem-sucedidas.",
    )
    parser.add_argument(
        "--delay", "-d",
        type=float,
        default=0.3,
        help="Delay em segundos entre requisições (padrão: 0.3s). Aumente se sofrer rate limit.",
    )
    args = parser.parse_args()

    token = args.token.strip()

    # 1. Decodifica o JWT
    print("\n🔐  Decodificando JWT...")
    try:
        payload = decode_jwt_payload(token)
        header = decode_jwt_header(token)
    except ValueError as e:
        print(f"[ERRO] {e}")
        sys.exit(1)

    # 2. Exibe info do token
    print_token_info(payload, header)

    # 3. Verifica se o token está expirado
    exp = payload.get("exp", 0)
    now_ts = int(datetime.now(tz=timezone.utc).timestamp())
    if exp and exp < now_ts:
        print(f"\n⚠️  AVISO: O token está EXPIRADO há {now_ts - exp} segundos.")
        print("   As chamadas à API provavelmente retornarão 401. Continue mesmo assim? [s/N] ", end="")
        answer = input().strip().lower()
        if answer not in ("s", "sim", "y", "yes"):
            print("Abortando.")
            sys.exit(0)

    # 4. Determina a base URL
    base_url = args.base_url
    if not base_url:
        tenant_id = payload.get("tenantId")
        area = payload.get("area")
        domain = payload.get("icDomain")

        if tenant_id:
            print(f"\n🌐  Descobrindo URL base via API Discovery (tenantId={tenant_id})...")
            base_url = discover_base_url(tenant_id, issuer=args.issuer)
            if base_url:
                print(f"   ✅ URL base detectada: {base_url}")
            else:
                print("   ⚠️  Descoberta falhou.")

        if not base_url and area and domain:
            base_url = f"https://api-{area}.{domain}"
            print(f"   📌 URL construída a partir do token: {base_url}")

        if not base_url:
            base_url = "https://api-na1.niceincontact.com"
            print(f"   📌 Usando URL padrão (NA1): {base_url}")

    # 5. Testa os endpoints
    results = test_endpoints(
        token=token,
        base_url=base_url,
        payload=payload,
        verbose=args.verbose,
        delay=args.delay,
    )

    # 6. Exibe o resumo
    print_summary(results)

    # 7. Salva em JSON se solicitado
    if args.output:
        save_results(results, payload, base_url, args.output)

    print("\n✅  Mapeamento concluído!\n")


if __name__ == "__main__":
    main()
