def decode_jwt_payload(token: str) -> dict:
    """Decodifica o payload de um JWT sem verificar assinatura."""
    try:
        parts = token.split(".")
        if len(parts) != 3:
            raise ValueError("Token JWT inválido: esperado 3 partes separadas por '.'")
        # Ajusta o padding do base64
        payload_b64 = parts[1]
        padding = 4 - len(payload_b64) % 4
        if padding != 4:
            payload_b64 += "=" * padding
        decoded = base64.urlsafe_b64decode(payload_b64)
        return json.loads(decoded)
    except Exception as e:
        raise ValueError(f"Não foi possível decodificar o JWT: {e}")


def decode_jwt_header(token: str) -> dict:
    """Decodifica o header de um JWT."""
    try:
        parts = token.split(".")
        header_b64 = parts[0]
        padding = 4 - len(header_b64) % 4
        if padding != 4:
            header_b64 += "=" * padding
        decoded = base64.urlsafe_b64decode(header_b64)
        return json.loads(decoded)
    except Exception:
        return {}


def discover_base_url(tenant_id: str, issuer: str = "https://cxone.niceincontact.com") -> Optional[str]:
    """
    Usa o endpoint de descoberta do CXone para obter a URL base correta da API.
    Retorna a api_endpoint ou None em caso de falha.
    """
    discovery_url = f"{issuer}/.well-known/cxone-configuration"
    try:
        resp = requests.get(
            discovery_url,
            params={"tenantId": tenant_id},
            timeout=10
        )
        if resp.status_code == 200:
            data = resp.json()
            return data.get("api_endpoint")
    except Exception:
        pass
    return None


def format_status(code: int) -> str:
    """Formata o código HTTP com símbolo visual."""
    if code == 200:
        return f"✅ {code} OK"
    elif code == 201:
        return f"✅ {code} Created"
    elif code == 204:
        return f"✅ {code} No Content"
    elif code in (400, 422):
        return f"⚠️  {code} Bad Request (endpoint existe mas parâmetros precisam ajuste)"
    elif code == 401:
        return f"🔒 {code} Unauthorized"
    elif code == 403:
        return f"🚫 {code} Forbidden (sem permissão)"
    elif code == 404:
        return f"❓ {code} Not Found"
    elif code == 405:
        return f"⚠️  {code} Method Not Allowed"
    elif code == 429:
        return f"⏳ {code} Rate Limited"
    elif 500 <= code < 600:
        return f"💥 {code} Server Error"
    else:
        return f"❔ {code}"


def is_accessible(code: int) -> bool:
    """Considera que o endpoint é acessível se não retornar 401 ou 403."""
    return code not in (401, 403)


